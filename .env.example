# Short name of your Obsidian vault (the folder name shown in Obsidian).
# Used as: obsidian vault="VAULT_NAME" ...
# Example: if your vault is at /home/user/notes, set VAULT_NAME=notes
VAULT_NAME=

# Absolute path to your Obsidian vault folder (used for setup checks).
# Example (Linux/macOS): VAULT_PATH=/home/user/ObsidianVault
# Example (Windows/Git Bash): VAULT_PATH=/c/Users/YourName/Documents/MyVault
VAULT_PATH=

# Language for generated report content (default: English).
# Any language works: French, Spanish, German, Japanese...
# This is passed as the `language=` argument to the skill.
LANGUAGE=English

# Day of the week that triggers the weekly report (default: 5 = Friday).
# Use ISO weekday numbers: 1=Monday 2=Tuesday 3=Wednesday 4=Thursday 5=Friday 6=Saturday 7=Sunday
# Example: set to 7 if your work week runs Monday–Sunday
WEEK_END_DAY=5

# GitHub personal access token: required ONLY for private repos accessed via HTTPS
# Generate one at: https://github.com/settings/tokens (scope: repo)
# Leave empty if you use SSH or only public repos.
GITHUB_TOKEN=

# Directories to scan when running /report-orchestrator discover
# Colon-separated list of absolute paths. Subdirectories are searched recursively (max depth 4).
# Default: ~/projects:~/repos:~/code:~/workspace:~/dev
DISCOVER_PATHS=
